<Window x:Class="AirportQueueVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AirportQueueVisualizer"
        mc:Ignorable="d"
        Title="Система управління аеропортом" 
        Height="800" Width="1400"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" Background="{DynamicResource AccentColor}" Padding="15">
            <TextBlock Text="{DynamicResource MainTitle}"
                       Foreground="White" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Left" Width="220" Background="{DynamicResource PrimaryColor}">
            <Grid>
                <StackPanel Margin="0,20,0,0" VerticalAlignment="Top">
                    <TextBlock Text="{DynamicResource MenuNav}" Foreground="#7F8C8D" FontSize="12" FontWeight="Bold" Margin="15,0,0,10"/>

                    <Button Content="{DynamicResource MenuHome}" Click="GoToHome"
                        Margin="10,5" Padding="10,8"
                        Background="#34495E" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" FontSize="14"/>

                    <Button Content="{DynamicResource MenuQueue}" Click="GoToQueue"
                        Margin="10,5" Padding="10,8"
                        Background="#34495E" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" FontSize="14"/>

                    <Button Content="{DynamicResource MenuInfo}" Click="GoToInfo"
                        Margin="10,5" Padding="10,8"
                        Background="#34495E" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" FontSize="14"/>
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom" Margin="10,20">
                    <Button Content="{DynamicResource Theme}" Click="ToggleTheme_Click"
                            Margin="0,0,0,10" Padding="10,8"
                            Background="{DynamicResource AccentColor}" Foreground="White" BorderThickness="0"/>

                    <Button Content="Ua / En" Click="ChangeLanguage_Click"
                        Padding="10,8"
                        Background="{DynamicResource AccentColor}" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="{DynamicResource BgColor}" Padding="15">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>

    </DockPanel>
</Window>