<Window x:Class="AirportQueueVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AirportQueueVisualizer"
        mc:Ignorable="d"
        Title="Система управління аеропортом" 
        Height="500" Width="1000"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="10,20">
                <TextBlock Text="Меню" Foreground="White" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Button Content="Головна" Click="GoToHome" Margin="0,5" Padding="5"/>
                <Button Content="Черга" Click="GoToQueue" Margin="0,5" Padding="5"/>
                <Button Content="Інформація" Click="GoToInfo" Margin="0,5" Padding="5"/>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
