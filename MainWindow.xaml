<Window x:Class="AirportQueueVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AirportQueueVisualizer"
        mc:Ignorable="d"
        Title="Система управління аеропортом" 
        Height="500" Width="1000"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" Background="#1ABC9C" Padding="15">
            <TextBlock Text="✈️ Візуалізатор черги аеропорту"
                       Foreground="White" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#BDC3C7" Padding="5,2">
            <Grid>
                <TextBlock Text="Статус: Система готова до роботи" FontSize="12" Foreground="#333" HorizontalAlignment="Left"/>
                <TextBlock Text="Версія 1.0" FontSize="12" Foreground="#333" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Left" Width="220" Background="#2C3E50">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="Навігація" Foreground="#7F8C8D" FontSize="12" FontWeight="Bold" Margin="15,0,0,10"/>

                <Button Content="🏠 Головна сторінка" Click="GoToHome"
                        Margin="10,5" Padding="10,8"
                        Background="#34495E" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" FontSize="14"/>

                <Button Content="👥 Управління чергою" Click="GoToQueue"
                        Margin="10,5" Padding="10,8"
                        Background="#34495E" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" FontSize="14"/>

                <Button Content="ℹ️ Інформація" Click="GoToInfo"
                        Margin="10,5" Padding="10,8"
                        Background="#34495E" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" FontSize="14"/>
            </StackPanel>
        </Border>

        <Border Background="#F4F6F6" Padding="15">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>

    </DockPanel>
</Window>