<Window x:Class="AirportQueueVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AirportQueueVisualizer"
        mc:Ignorable="d"
        Title="Система управління аеропортом" 
        Height="500" Width="1000"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="✈️ АЕРОПОРТ"
                           Foreground="White" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button x:Name="BtnHome" Content="Головна"
                        Height="40" Margin="10,5" FontSize="16"
                        Background="#34495E" Foreground="White" BorderThickness="0"
                        Click="BtnHome_Click"/>

                <Button x:Name="BtnQueue" Content="Черга"
                        Height="40" Margin="10,5" FontSize="16"
                        Background="#34495E" Foreground="White" BorderThickness="0"
                        Click="BtnQueue_Click"/>

                <Button x:Name="BtnInfo" Content="Інформація"
                        Height="40" Margin="10,5" FontSize="16"
                        Background="#34495E" Foreground="White" BorderThickness="0"
                        Click="BtnInfo_Click"/>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
