<Page x:Class="AirportQueueVisualizer.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AirportQueueVisualizer"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePage">

    <Grid Margin="30">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="600">
            <TextBlock Text="🛫" FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Ласкаво просимо!"
                       Style="{StaticResource HeaderStyle}"
                       FontSize="32"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Система «Візуалізатор черги аеропорту» розроблена для ефективного керування пасажиропотоком. Вона дозволяє швидко реєструвати пасажирів на рейси, формувати списки черг та редагувати їх у реальному часі."
                       FontSize="16"
                       Foreground="{StaticResource TextColor}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       LineHeight="24"
                       Margin="0,0,0,30"/>

            <Border Background="{StaticResource BgColor}" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Швидкий старт:" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <TextBlock Text="Перейдіть до розділу «Управління чергою» у боковому меню, щоб розпочати роботу з даними пасажирів." FontSize="14" Foreground="#555" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
