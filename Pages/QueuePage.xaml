<Page x:Class="AirportQueueVisualizer.Pages.QueuePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AirportQueueVisualizer"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="QueuePage">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.5"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource QueueMainTitle}" Style="{DynamicResource HeaderStyle}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <StackPanel Margin="0,0,15,0">
                <TextBlock Text="{DynamicResource QueuePassengerName}" Foreground="{DynamicResource TextColor}" Margin="0,0,0,5"/>
                <TextBox Width="180" Height="28"
                         Text="{Binding CurrentPassenger.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Margin="0,0,15,0">
                <TextBlock Text="{DynamicResource QueueFlightNumber}" Foreground="{DynamicResource TextColor}" Margin="0,0,0,5"/>
                <TextBox Width="120" Height="28"
                         Text="{Binding CurrentPassenger.Flight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <Button x:Name="BtnAddOrUpdate" Content="{DynamicResource BtnAdd}" Style="{DynamicResource GreenButton}" Width="100" Height="30" VerticalAlignment="Bottom" Click="AddOrUpdate_Click"/>
            <Button x:Name="BtnCancelEdit" Content="{DynamicResource BtnCancel}" Width="90" Height="30" VerticalAlignment="Bottom" Margin="10,0,0,0" Click="CancelEdit_Click" Visibility="Collapsed"/>
        </StackPanel>

        <ListBox x:Name="PassengerList" ItemsSource="{Binding Passengers}" Grid.Row="2" Margin="0,0,0,15" Background="{DynamicResource BgColor}" BorderBrush="#BDC3C7">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Margin="0,0,10,0" Foreground="{DynamicResource TextColor}"/>
                        <TextBlock Text="{Binding Flight, StringFormat='(Рейс: {0})'}" Foreground="#7F8C8D" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="{DynamicResource BtnEdit}" Style="{DynamicResource BlueButton}" Width="120" Height="30" Margin="0,0,10,0" Click="Edit_Click"/>
            <Button Content="{DynamicResource BtnDelete}" Style="{DynamicResource RedButton}" Width="120" Height="30" Click="Delete_Click"/>
        </StackPanel>
    </Grid>
</Page>
