<Page x:Class="AirportQueueVisualizer.Pages.InfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AirportQueueVisualizer"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="InfoPage">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.5"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Grid Margin="30">
        <StackPanel MaxWidth="700" HorizontalAlignment="Left">

            <TextBlock Text="{DynamicResource InfoTitle}" Style="{DynamicResource HeaderStyle}" FontSize="28"/>

            <TextBlock Text="{DynamicResource InfoUsage}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource PrimaryColor}" Margin="0,20,0,10"/>

            <StackPanel Margin="15,0,0,20">
                <TextBlock Text="{DynamicResource InfoStep1}" FontSize="15" Foreground="{DynamicResource TextColor}" Margin="0,0,0,5"/>
                <TextBlock Text="{DynamicResource InfoStep2}" FontSize="15" Foreground="{DynamicResource TextColor}" Margin="0,0,0,5"/>
                <TextBlock Text="{DynamicResource InfoStep3}" FontSize="15" Foreground="{DynamicResource TextColor}" Margin="0,0,0,5"/>
                <TextBlock Text="{DynamicResource InfoStep4}" FontSize="15" Foreground="{DynamicResource TextColor}" Margin="0,0,0,5"/>
            </StackPanel>

            <Separator Margin="0,10,0,20" Background="#BDC3C7"/>

            <TextBlock Text="{DynamicResource InfoDeveloper}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,10"/>

            <Border Background="{DynamicResource BgColor}" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="{DynamicResource InfoProject}" FontSize="15" Foreground="{DynamicResource TextColor}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource InfoAuthor}" FontSize="15" Foreground="{DynamicResource TextColor}" FontWeight="Medium" Margin="0,0,0,5"/>
                    <TextBlock Text="{DynamicResource InfoCollege}" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="{DynamicResource InfoVersion}" FontSize="14" Foreground="Gray" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </Grid>
</Page>
