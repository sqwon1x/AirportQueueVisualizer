<Page x:Class="AirportQueueVisualizer.Pages.InfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AirportQueueVisualizer"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="InfoPage">

    <Grid Margin="30">
        <StackPanel MaxWidth="700" HorizontalAlignment="Left">

            <TextBlock Text="Довідкова інформація" Style="{StaticResource HeaderStyle}" FontSize="28"/>

            <TextBlock Text="📖 Як користуватися програмою:" FontWeight="Bold" FontSize="18" Foreground="{StaticResource PrimaryColor}" Margin="0,20,0,10"/>

            <StackPanel Margin="15,0,0,20">
                <TextBlock Text="1. Реєстрація: Введіть ім'я пасажира та номер рейсу у відповідні поля." FontSize="15" Margin="0,0,0,5"/>
                <TextBlock Text="2. Додавання: Натисніть зелену кнопку «Додати», щоб внести пасажира до списку." FontSize="15" Margin="0,0,0,5"/>
                <TextBlock Text="3. Видалення: Оберіть пасажира у списку кліком миші та натисніть червону кнопку «Видалити»." FontSize="15" Margin="0,0,0,5"/>
                <TextBlock Text="4. Валідація: Програма не дозволить додати пасажира, якщо поля введення порожні." FontSize="15" Margin="0,0,0,5"/>
            </StackPanel>

            <Separator Margin="0,10,0,20" Background="#BDC3C7"/>

            <TextBlock Text="👨‍💻 Про розробника:" FontWeight="Bold" FontSize="18" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,10"/>

            <Border Background="{StaticResource BgColor}" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Проєкт створено в рамках проходження навчальної практики." FontSize="15" Margin="0,0,0,8"/>
                    <TextBlock Text="Розробник: студент групи КН-23 Гутич Михайло" FontSize="15" FontWeight="Medium" Margin="0,0,0,5"/>
                    <TextBlock Text="ДВНЗ «Ужгородський національний університет»" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="Версія: 1.0 (2026 рік)" FontSize="14" Foreground="Gray" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </Grid>
</Page>
